# Per-machine env for the claude-voice-daemon systemd user service.
# Copy to ~/.config/voice-assistant/daemon.env and edit. The service reads
# it via EnvironmentFile=, so changes take effect on `systemctl --user
# restart claude-voice-daemon`.

# Where the Windows host's TTS server listens. The `speak` CLI -- which
# Claude calls as a tool -- POSTs to <VOICE_TTS_URL>/speak. Replace with
# the host's LAN address. Confirmed reachable from the VM in install-host.ps1
# via the Windows firewall rule for TCP 8002.
VOICE_TTS_URL=http://192.168.1.10:8002

# Absolute path to the `claude` CLI. The unit inherits a minimal PATH so
# resolving by name can fail; setting an absolute path is more reliable.
# On NixOS this is the per-user profile symlink, which nix-rebuild keeps
# pointing at the current claude-code package.
VOICE_CLAUDE_BIN=/etc/profiles/per-user/taylorl/bin/claude

# Bind address for the daemon's HTTP listener. Defaults to 0.0.0.0 in the
# unit file (so the Windows orchestrator can call POST /ask). Override to
# 127.0.0.1 if you want to lock it to the loopback interface.
# VOICE_CLAUDE_HOST=0.0.0.0

# Port the daemon listens on. Defaults to 8003.
# VOICE_CLAUDE_PORT=8003

# Workspace + state-dir overrides (rarely needed). Defaults are
# ~/voice-assistant and ~/.local/state/voice-assistant respectively.
# VOICE_WORKSPACE=%h/voice-assistant
# VOICE_STATE_DIR=%h/.local/state/voice-assistant

# Main-thread model. Defaults to "haiku" — the main thread orchestrates
# `speak` + subagent dispatch and benefits from low latency far more than
# from raw reasoning power. Subagents pick their own model per task,
# guided by the runtime CLAUDE.md.
# VOICE_CLAUDE_MODEL=haiku
# VOICE_CLAUDE_FALLBACK_MODEL=sonnet
